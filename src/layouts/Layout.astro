---
interface Props {
  title?: string;
}
const { title = 'Hare Om (Zaw Zaw Win) — Software Developer in Bangkok, Chiang Mai & Myanmar' } = Astro.props;
const description = 'Hare Om (Zaw Zaw Win) — Software Developer based in Bangkok & Chiang Mai. 6+ years building web apps, mobile apps, and AI products with JavaScript and PHP. Available for freelance work in Thailand and Myanmar (Yangon).';
const siteUrl = 'https://hareom284.com';
const ogImage = `${siteUrl}/og-image.png`;
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="hareom284, Hare Om, Zaw Zaw Win, Software Developer Bangkok, Software Developer Chiang Mai, Software Developer Myanmar, Software Developer Yangon, web developer Thailand, PHP developer, JavaScript developer, AI developer, freelance developer Bangkok, freelance developer Myanmar" />
  <meta name="author" content="Hare Om (Zaw Zaw Win)" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={siteUrl} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:site_name" content="Hare Om — Portfolio" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={siteUrl} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicons (profile picture) -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Web App Manifest -->
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0a0a14" />

  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Hare Om",
    "alternateName": ["Zaw Zaw Win", "hareom284"],
    "url": siteUrl,
    "image": ogImage,
    "jobTitle": "Software Developer",
    "description": description,
    "knowsAbout": ["JavaScript", "PHP", "Web Development", "Mobile Development", "AI", "Software Engineering"],
    "address": [
      { "@type": "PostalAddress", "addressLocality": "Bangkok", "addressCountry": "TH" },
      { "@type": "PostalAddress", "addressLocality": "Chiang Mai", "addressCountry": "TH" },
      { "@type": "PostalAddress", "addressLocality": "Yangon", "addressCountry": "MM" }
    ],
    "sameAs": [
      "https://www.linkedin.com/in/hareom284/",
      "https://github.com/hareom284",
      "https://www.upwork.com/freelancers/~0142b35bde73ee6ef7"
    ]
  })} />

  <!-- Google Analytics -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-ZMSD9B4J4D"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-ZMSD9B4J4D');
  </script>

  <!-- Restore saved theme BEFORE paint -->
  <script is:inline>
    (function() {
      var saved = localStorage.getItem('theme');
      if (saved === 'light' || saved === 'dark') {
        document.documentElement.setAttribute('data-theme', saved);
      }
    })();
  </script>
</head>
<body>
  <div class="gradient-bg"></div>

  <slot />

  <style is:global>
    @import '../styles/global.css';
  </style>
</body>
</html>
