<section id="contact" class="section contact-section">
  <!-- ambient glow -->
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:600px;background:radial-gradient(circle, var(--accent-glow), transparent 55%);pointer-events:none;"></div>
  <div style="position:absolute;top:35%;left:65%;width:300px;height:300px;background:radial-gradient(circle, var(--purple-glow), transparent 55%);pointer-events:none;"></div>

  <div class="mono" style="font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent);margin-bottom:20px;position:relative;">
    Let's Begin
  </div>
  <h2 class="contact-title" style="position:relative;">
    Have an idea?<br/><span class="gradient-text">Let's build it.</span>
  </h2>
  <p style="font-size:17px;color:var(--ink-mute);max-width:480px;margin:0 auto 40px;line-height:1.65;position:relative;">
    No pitch deck needed. Tell me what's on your mind — I'll tell you honestly if I can help.
  </p>
  <div class="contact-buttons" style="position:relative;">
    <a href="https://www.linkedin.com/in/hareom284/" target="_blank" class="btn-primary">
      LinkedIn · hareom284 →
    </a>
    <a href="https://www.upwork.com/freelancers/~0142b35bde73ee6ef7" target="_blank" class="btn-outline">
      Hire on Upwork
    </a>
    <a href="https://github.com/hareom284" target="_blank" class="btn-outline">
      GitHub
    </a>
  </div>
</section>
