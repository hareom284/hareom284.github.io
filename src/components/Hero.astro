---
---
<section class="hero-section">
  <div class="hero-grid">
    <div>
      <div class="mono reveal hero-subtitle">
        <span style="width:24px;height:2px;background:linear-gradient(90deg, var(--accent), var(--purple));border-radius:2px;display:inline-block;"></span>
        Software engineer · AI builder · 2026
      </div>
      <h1 class="reveal hero-title" style="animation-delay:0.1s;">
        Ideas into<br/>
        <span class="gradient-text">working</span> systems —<br/>
        <span style="color:var(--ink-mute);">quietly</span> engineered.
      </h1>
      <p class="reveal hero-desc" style="animation-delay:0.25s;">
        I'm <span style="color:var(--ink);font-weight:600;">Hare Om</span> — a software engineer who ships full products:
        web, mobile, and the AI layer on top. JavaScript and PHP.
        Six years of building systems that real teams actually use every day.
      </p>
      <div class="reveal hero-buttons" style="animation-delay:0.4s;">
        <a href="#contact" class="btn-primary">
          Start a project
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M5 12h14m-5-5l5 5-5 5"/>
          </svg>
        </a>
        <a href="#work" class="btn-outline">See the work</a>
      </div>

      <div class="stats-strip reveal" style="animation-delay:0.55s;">
        <div class="glass stat-card">
          <div class="stat-number"><span class="gradient-text">6+</span></div>
          <div class="stat-label">years shipping</div>
        </div>
        <div class="glass stat-card">
          <div class="stat-number"><span class="gradient-text">8k</span></div>
          <div class="stat-label">daily users</div>
        </div>
        <div class="glass stat-card">
          <div class="stat-number"><span class="gradient-text">LMS</span></div>
          <div class="stat-label">DDD production</div>
        </div>
        <div class="glass stat-card">
          <div class="stat-number"><span class="gradient-text">AI</span></div>
          <div class="stat-label">agents & tools</div>
        </div>
      </div>
    </div>

    <!-- Portrait -->
    <div class="reveal hero-portrait" style="animation-delay:0.5s;">
      <div class="portrait-wrap">
        <div class="orbit" style="position:absolute;top:50%;left:50%;width:120%;height:120%;border:1px solid var(--glass-border);border-radius:50%;pointer-events:none;z-index:0;"></div>
        <div class="orbit" style="position:absolute;top:50%;left:50%;width:140%;height:140%;border:1px dashed rgba(176,124,255,0.1);border-radius:50%;pointer-events:none;z-index:0;animation-direction:reverse;animation-duration:65s;"></div>
        <div class="portrait-img-wrap glow-breathe">
          <img src="/portrait.jpg" alt="Hare Om" />
          <div style="position:absolute;bottom:0;left:0;right:0;height:40%;background:linear-gradient(to top, var(--bg-gradient-1), transparent);"></div>
        </div>
        <div class="mono glass-strong float id-card">
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--ink-dim);">ID</span><span style="color:var(--accent);">/ 347</span>
          </div>
          <div style="height:1px;background:linear-gradient(90deg, var(--accent), var(--purple), transparent);margin:6px 0;border-radius:1px;"></div>
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--ink-dim);">ROLE</span><span style="color:var(--ink-secondary);">SWE + AI</span>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--ink-dim);">STACK</span><span style="color:var(--ink-secondary);">JS / PHP</span>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--ink-dim);">STATUS</span><span style="color:var(--sage);">● OPEN</span>
          </div>
        </div>
        <div class="glass-strong badge">
          <span class="pulse" style="width:8px;height:8px;background:var(--sage);border-radius:50%;display:inline-block;box-shadow:0 0 12px var(--teal-glow);"></span>
          Open for work
        </div>
      </div>
    </div>
  </div>
</section>
