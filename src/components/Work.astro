---
---
<section id="work" class="section">
  <div class="section-inner">
    <div class="mono section-label">02 — Real Problems Solved</div>
    <h2 class="section-title">
      Stories, <span class="gradient-text">not screenshots.</span>
    </h2>
    <p class="section-desc">
      What matters isn't what I built — it's what changed because of it.
    </p>

    <div class="work-grid">
      <!-- HR System -->
      <div class="card work-hero">
        <div style="position:relative;z-index:1;">
          <div class="mono" style="font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-dim);display:flex;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:8px;">
            <span>Case 01 / Flagship HR System — Myanmar</span>
            <span style="display:flex;align-items:center;gap:5px;"><span style="width:6px;height:6px;background:var(--sage);border-radius:50%;display:inline-block;box-shadow:0 0 8px var(--teal-glow);"></span> 8k DAU · Shipped</span>
          </div>
          <h3 class="work-hero-title">
            A country's HR, <span class="gradient-text">quietly running</span><br/>on 8,000 people's mornings.
          </h3>
          <p style="font-size:15px;color:var(--ink-mute);max-width:580px;line-height:1.65;">
            A comprehensive HR platform used daily by 8,000+ employees across Myanmar.
            Onboarding, payroll, leave, attendance, overtime, offboarding, activity audit — all unified.
            PHP · JavaScript.
          </p>
        </div>
        <div class="work-hero-stats" style="position:relative;z-index:1;">
          <div class="glass" style="padding:14px;border-radius:14px;">
            <div class="mono" style="font-size:9px;letter-spacing:0.1em;color:var(--accent);text-transform:uppercase;margin-bottom:6px;">Scale</div>
            <p style="font-size:13px;color:var(--ink-mute);line-height:1.4;">8,000+ daily users</p>
          </div>
          <div class="glass" style="padding:14px;border-radius:14px;">
            <div class="mono" style="font-size:9px;letter-spacing:0.1em;color:var(--accent);text-transform:uppercase;margin-bottom:6px;">Stack</div>
            <p style="font-size:13px;color:var(--ink-mute);line-height:1.4;">PHP · JavaScript</p>
          </div>
          <div class="glass" style="padding:14px;border-radius:14px;">
            <div class="mono" style="font-size:9px;letter-spacing:0.1em;color:var(--accent);text-transform:uppercase;margin-bottom:6px;">Scope</div>
            <p style="font-size:13px;color:var(--ink-mute);line-height:1.4;">8 major modules</p>
          </div>
          <div class="glass" style="padding:14px;border-radius:14px;">
            <div class="mono" style="font-size:9px;letter-spacing:0.1em;color:var(--accent);text-transform:uppercase;margin-bottom:6px;">Status</div>
            <p style="font-size:13px;color:var(--ink-mute);line-height:1.4;">Production · multi-year</p>
          </div>
        </div>
      </div>

      <!-- LMS -->
      <div class="card work-side">
        <div style="position:relative;z-index:1;">
          <div class="mono" style="font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-dim);display:flex;justify-content:space-between;margin-bottom:16px;">
            <span>Case 02 / LMS</span>
            <span style="display:flex;align-items:center;gap:5px;"><span style="width:6px;height:6px;background:var(--sage);border-radius:50%;display:inline-block;box-shadow:0 0 8px var(--teal-glow);"></span> Live</span>
          </div>
          <h3 style="font-size:24px;line-height:1.15;letter-spacing:-0.02em;font-weight:700;margin-bottom:12px;">
            A learning platform, <span class="gradient-text">built to last.</span>
          </h3>
          <p style="font-size:13px;color:var(--ink-mute);line-height:1.6;">
            14-month build with PHP and JavaScript using Domain-Driven Design and
            the repository pattern. Real separation of concerns, real testability.
          </p>
        </div>
        <div class="mono" style="font-size:10px;letter-spacing:0.06em;color:var(--ink-dim);line-height:2.2;margin-top:16px;position:relative;z-index:1;">
          <div style="display:flex;align-items:center;gap:6px;"><span style="color:var(--accent);">→</span> DDD · layered domain</div>
          <div style="display:flex;align-items:center;gap:6px;"><span style="color:var(--accent);">→</span> Repository pattern</div>
          <div style="display:flex;align-items:center;gap:6px;"><span style="color:var(--accent);">→</span> SSR bridge</div>
          <div style="display:flex;align-items:center;gap:6px;"><span style="color:var(--accent);">→</span> 14 mo · Jan 23 → Mar 24</div>
        </div>
      </div>

      <!-- Metric tiles -->
      <div class="card work-metric">
        <div class="mono" style="font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-dim);position:relative;z-index:1;">Case 03 / Automation</div>
        <div style="position:relative;z-index:1;">
          <div class="gradient-text metric-number">200h</div>
          <div class="metric-label">Saved / month</div>
        </div>
      </div>
      <div class="card work-metric">
        <div class="mono" style="font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-dim);position:relative;z-index:1;">Case 04 / AI Integration</div>
        <div style="position:relative;z-index:1;">
          <div class="gradient-text metric-number">AI</div>
          <div class="metric-label">Integrated into workflows</div>
        </div>
      </div>
      <div class="card work-metric">
        <div class="mono" style="font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-dim);position:relative;z-index:1;">Case 05 / Deployment</div>
        <div style="position:relative;z-index:1;">
          <div class="gradient-text metric-number">99.9<span style="font-size:0.5em;">%</span></div>
          <div class="metric-label">Uptime sustained</div>
        </div>
      </div>
    </div>
  </div>
</section>
